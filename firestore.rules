rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Remove the overly restrictive default rule
    // match /{document=**} {
    //   allow read, write: if false;
    // }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Users
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
    }

    // User Configs
    match /userConfigs/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    // Menus
    match /menus/{menuId} {
        allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
        allow create: if isSignedIn() && request.auth.uid == incoming().userId && isValidId(menuId);
        allow update: if isSignedIn() && request.auth.uid == existing().userId && request.auth.uid == incoming().userId;
        allow delete: if isSignedIn() && request.auth.uid == existing().userId;
    }

    // Add a rule for any other documents that might be accessed
match /{document=**} {
  allow read: if true;
  allow write: if false;
}
  }
}
